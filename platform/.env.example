# Solar Strive Environment Configuration
# Copy this file to .env.local and fill in your actual values

# === Frontend Configuration ===
# Mapbox GL JS for interactive maps
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# ArkadeOS Configuration for Bitcoin payments
NEXT_PUBLIC_ARKADE_SERVER_URL=https://mutinynet.arkade.sh
NEXT_PUBLIC_ESPLORA_URL=https://mutinynet.com/api

# API Endpoints
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# === Backend Configuration ===
# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/solar_strive
REDIS_URL=redis://localhost:6379

# ArkadeOS Backend Configuration
ARKADE_SERVER_URL=https://mutinynet.arkade.sh
ESPLORA_URL=https://mutinynet.com/api
ARKADE_MASTER_PRIVATE_KEY=your_platform_wallet_private_key_hex

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Powur API Integration
POWUR_API_URL=https://api.powur.com/v1
POWUR_API_KEY=your_powur_api_key_here
POWUR_AFFILIATE_ID=your_powur_affiliate_id

# File Storage (AWS S3 or IPFS)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=solar-strive-uploads

# Or IPFS for decentralized storage
IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API_URL=https://api.pinata.cloud

# External Services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
OPENWEATHER_API_KEY=your_openweather_api_key

# Monitoring and Analytics
SENTRY_DSN=your_sentry_dsn_for_error_tracking
ANALYTICS_TRACKING_ID=your_analytics_id

# === Development Tools ===
# Database Tools
PGADMIN_DEFAULT_EMAIL=admin@solarstrive.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# Redis Tools
REDIS_COMMANDER_PASSWORD=redis_password

# === Production Overrides ===
# Set these in production environment
# DATABASE_URL=postgresql://prod_user:prod_password@prod_db:5432/solar_strive_prod
# REDIS_URL=redis://prod_redis:6379
# ARKADE_SERVER_URL=https://mainnet.arkade.sh
# ESPLORA_URL=https://blockstream.info/api
# NODE_ENV=production